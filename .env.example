# =====================================================================
# SHServices V2 · Plantilla de variables de entorno
# ---------------------------------------------------------------------
# Copia este archivo a `.env` y completa los valores.
# NO subas el `.env` real al repositorio (ya está en .gitignore).
# Aquí solo hay valores por defecto o vacíos — nunca secretos reales.
# =====================================================================

# --- POSTGRESQL -------------------------------------------------------
# Base de datos compartida por todos los microservicios con estado.
POSTGRES_USER=admin
POSTGRES_PASSWORD=            # <-- define una contraseña segura
POSTGRES_DB=shservices_db
# Cadena de conexión que consumen los servicios (host = nombre del contenedor).
DATABASE_URL=postgresql://admin:CHANGE_ME@postgres-db:5432/shservices_db

# --- RABBITMQ ---------------------------------------------------------
# Bus de eventos (exchange topic "tickets.eventos").
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=            # <-- define una contraseña segura
RABBITMQ_URL=amqp://guest:CHANGE_ME@rabbitmq:5672/

# --- SEGURIDAD / JWT --------------------------------------------------
# DEBE ser idéntica en api-gateway y auth-service o los tokens no validan.
JWT_SECRET_KEY=            # <-- cadena larga y aleatoria

# --- API GATEWAY ------------------------------------------------------
# Orígenes permitidos por CORS (separa por comas). El frontend corre en :3001.
CORS_ORIGINS=http://localhost:3001

# --- AUTH SERVICE -----------------------------------------------------
# (Usa JWT_SECRET_KEY de la sección SEGURIDAD; sin variables propias.)

# --- GRAFANA ----------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=            # <-- define una contraseña segura

# --- FRONTEND (Next.js · archivo frontend/.env.local) -----------------
# El login va DIRECTO al auth-service; el resto pasa por el Gateway.
AUTH_SERVICE_URL=http://localhost:8003
GATEWAY_URL=http://localhost:8000
# JWT_SECRET_KEY (mismo valor de arriba) para verificar la firma en el middleware.
SESSION_COOKIE_NAME=sh_session
