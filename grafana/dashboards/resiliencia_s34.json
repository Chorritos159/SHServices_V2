{
  "id": null,
  "uid": "shservices-resiliencia-s34",
  "title": "SHServices — Resiliencia (S34)",
  "description": "Circuit breaker, retry/fallback, bulkhead, rate limit, throughput/latencia/error rate del Gateway y queue depth/consumer lag de RabbitMQ.",
  "tags": ["shservices", "resiliencia", "s34"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    { "id": 100, "type": "row", "title": "Throughput, latencia y error rate (Gateway)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false },

    {
      "id": 1, "type": "timeseries", "title": "Throughput (req/s)",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"api-gateway\"}[1m]))", "legendFormat": "req/s" }
      ]
    },
    {
      "id": 2, "type": "timeseries", "title": "Latencia p50 / p95 / p99 (Gateway)",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"api-gateway\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"api-gateway\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"api-gateway\"}[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 3, "type": "timeseries", "title": "Error rate (%) — 5xx del Gateway",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "targets": [
        { "expr": "100 * sum(rate(http_requests_total{job=\"api-gateway\",status=~\"5..\"}[1m])) / clamp_min(sum(rate(http_requests_total{job=\"api-gateway\"}[1m])), 1e-9)", "legendFormat": "% error" }
      ]
    },

    { "id": 101, "type": "row", "title": "Circuit Breaker", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 }, "collapsed": false },

    {
      "id": 4, "type": "state-timeline", "title": "Estado del circuito por servicio (CLOSED / HALF_OPEN / OPEN)",
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "HALF_OPEN", "color": "yellow" }, "2": { "text": "OPEN", "color": "red" } } }
          ],
          "custom": { "lineWidth": 0, "fillOpacity": 100 }
        },
        "overrides": []
      },
      "options": { "mergeValues": true, "showValue": "always" },
      "targets": [
        { "expr": "gateway_circuit_state", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 5, "type": "stat", "title": "Aperturas de circuito (total acumulado)",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": {} }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "gateway_circuit_opens_total", "legendFormat": "{{service}}" }
      ]
    },

    { "id": 102, "type": "row", "title": "Retry, fallback y timeouts", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }, "collapsed": false },

    {
      "id": 6, "type": "timeseries", "title": "Reintentos (retries/s) por servicio",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(gateway_retries_total[1m])) by (service)", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Fallbacks entregados (/s) por servicio",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(gateway_fallbacks_total[1m])) by (service)", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Timeouts (/s) por servicio",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(gateway_timeouts_total[1m])) by (service)", "legendFormat": "{{service}}" }
      ]
    },

    { "id": 103, "type": "row", "title": "Contención: bulkhead y rate limit (Fase 2)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }, "collapsed": false },

    {
      "id": 9, "type": "timeseries", "title": "Bulkhead: llamadas en vuelo por servicio",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        { "expr": "gateway_bulkhead_in_flight", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "Bulkhead: rechazos (/s) por razón",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 40, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(gateway_bulkhead_rejects_total[1m])) by (service, razon)", "legendFormat": "{{service}} / {{razon}}" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Rate limit global: rechazos (/s) — 429",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "targets": [
        { "expr": "rate(gateway_rate_limit_rejects_total[1m])", "legendFormat": "429/s" }
      ]
    },

    { "id": 104, "type": "row", "title": "RabbitMQ: queue depth y consumer lag", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }, "collapsed": false },

    {
      "id": 12, "type": "timeseries", "title": "Queue depth — mensajes listos por cola",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        { "expr": "rabbitmq_queue_messages_ready{queue=~\".+\",queue!~\"amq.*\"}", "legendFormat": "{{queue}}" }
      ]
    },
    {
      "id": 13, "type": "timeseries", "title": "Consumer lag — mensajes sin confirmar (unacked) por cola",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        { "expr": "rabbitmq_queue_messages_unacked{queue=~\".+\",queue!~\"amq.*\"}", "legendFormat": "{{queue}}" }
      ]
    },
    {
      "id": 14, "type": "timeseries", "title": "Consumidores activos por cola",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "rabbitmq_queue_consumers{queue=~\".+\",queue!~\"amq.*\"}", "legendFormat": "{{queue}}" }
      ]
    },

    { "id": 105, "type": "row", "title": "Desenlaces del proxy y sampling de logs", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 }, "collapsed": false },

    {
      "id": 15, "type": "timeseries", "title": "Requests proxied por desenlace (/s)",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(gateway_proxy_requests_total[1m])) by (outcome)", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "id": 16, "type": "stat", "title": "Logs de rutina muestreados (omitidos bajo carga)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "gateway_logs_sampled_total", "legendFormat": "muestreados" }
      ]
    }
  ]
}
